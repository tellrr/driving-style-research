# pipeline/.env — API keys for the research pipeline
# Copy this file to pipeline/.env and fill in the values.
# This file is safe to commit; pipeline/.env is gitignored.

# ── Claude API (required for daily strategic reports) ─────────────────────────
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-REPLACE_ME

# ── LLM provider for the main pipeline ───────────────────────────────────────
# Set LLM_PROVIDER to one of: ollama | gemini | openai | deepseek
# Then fill in only the key and model for the chosen provider.
LLM_PROVIDER=ollama

PIPELINE_MODEL_OLLAMA=qwen3.5:4b

GEMINI_API_KEY=
PIPELINE_MODEL_GEMINI=gemini-3.1-flash-lite-preview

OPENAI_API_KEY=
PIPELINE_MODEL_OPENAI=gpt-5-mini

# DeepSeek: get your key at https://platform.deepseek.com/
# Use deepseek-v4-flash (fast, cheap) or deepseek-v4-pro (more capable)
DEEPSEEK_API_KEY=
PIPELINE_MODEL_DEEPSEEK=deepseek-v4-flash

REPORT_MODEL=claude-opus-4-6

# ── Research Dashboard (optional) ────────────────────────────────────────────
# If you have a research-dashboard instance, fill in these values to push
# daily status, reports, and task outputs automatically.
# Leave blank to skip dashboard publishing (everything still runs locally).
#
# DASHBOARD_API_URL: base URL of your deployed research-dashboard instance
#   Example: https://research.yourdomain.com
#
# DASHBOARD_API_KEY: the API key generated by the dashboard admin panel
#   when you created this project (shown once at creation time)
DASHBOARD_API_URL=
DASHBOARD_API_KEY=
